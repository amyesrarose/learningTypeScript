// KeyOf and TypeOf together 
const rolesConfig = {
  admin: "Full Access",
  editor: "Edit Access",
  viewer: "Read Only"
};

// 1. typeof rolesConfig gives us the object's type structure
// 2. keyof extracts the keys from that structure
type RoleNames = keyof typeof rolesConfig;

// RoleNames is now: "admin" | "editor" | "viewer"

function assignRole(role: RoleNames) {
  console.log(`Assigning role: ${role}`);
}

assignRole("admin");  // Valid
//assignRole("guest");  // Error: Argument of type '"guest"' is not assignable
assignRole("viewer") // JS  auto suggests and allow only 3 value