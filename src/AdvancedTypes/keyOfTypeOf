// keyof  Operator.  > works like a getter in Java
// keyof only works on Types, you must first use typeof to turn the variable into a type.

type AppSettings = {
    theme: "light" | "dark";
    notificationsEnabled : boolean;
    maxUploadSizeMb: number;
    apiEndpoint : string;
}
const currentSettings: AppSettings = {
  theme: "dark",
  notificationsEnabled: true,
  maxUploadSizeMb: 50,
  apiEndpoint: "https://api.healthapp.com"
};


// SettingKeys is now: "theme" | "notificationsEnabled" | "maxUploadSizeMb" | "apiEndpoint"
type SettingKeys = keyof AppSettings;

function getSafeSetting(key: SettingKeys) { //  values of SettingKeys come only from "AppSettings"
  return currentSettings[key];
}

// 1. Valid Usage
const currentTheme = getSafeSetting("theme"); 

// 2. Prevented Typo
const backupUrl = getSafeSetting("apiEndpoint");  // when misspelled type script show and force to fix it

function getSetting<T>(source: T, propertyName : keyof T ){
    return source[propertyName];
}


